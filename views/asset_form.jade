extends layout

block content
  .page-header
    div
      h1.page-title #{action} Asset
      p.page-subtitle Enforce clean catalog data so asset issue, return, stock, and audit workflows stay trustworthy.

  .panel
    form(method='POST', action=`/asset/${action === 'Add' ? 'add' : 'edit/' + (asset ? asset.id : '')}`, novalidate)
      .row.g-3
        .col-md-6
          label.form-label(for='serial_number') Serial Number
          input#serial_number.form-control(class=errors.serial_number ? 'is-invalid' : '', type='text', name='serial_number', value=asset ? asset.serial_number : '', required)
          if errors.serial_number
            .invalid-feedback.d-block= errors.serial_number
        .col-md-6
          label.form-label(for='asset_type') Category
          select#asset_type.form-select(class=errors.asset_type ? 'is-invalid' : '', name='asset_type', required)
            option(value='') Select category
            each categoryName in categoryOptions
              option(value=categoryName, selected=(asset && asset.asset_type === categoryName))= categoryName
          if errors.asset_type
            .invalid-feedback.d-block= errors.asset_type
        .col-md-6
          label.form-label(for='make') Make
          input#make.form-control(class=errors.make ? 'is-invalid' : '', type='text', name='make', value=asset ? asset.make : '', required)
          if errors.make
            .invalid-feedback.d-block= errors.make
        .col-md-6
          label.form-label(for='model') Model
          input#model.form-control(class=errors.model ? 'is-invalid' : '', type='text', name='model', value=asset ? asset.model : '', required)
          if errors.model
            .invalid-feedback.d-block= errors.model
        .col-md-6
          label.form-label(for='purchase_date') Purchase Date
          input#purchase_date.form-control(class=errors.purchase_date ? 'is-invalid' : '', type='date', name='purchase_date', value=asset ? asset.purchase_date : '')
          if errors.purchase_date
            .invalid-feedback.d-block= errors.purchase_date
        .col-md-3
          label.form-label(for='purchase_price') Purchase Cost
          input#purchase_price.form-control(class=errors.purchase_price ? 'is-invalid' : '', type='number', step='0.01', min='0', name='purchase_price', value=asset ? asset.purchase_price : '')
          if errors.purchase_price
            .invalid-feedback.d-block= errors.purchase_price
        .col-md-3
          label.form-label(for='status') Status
          select#status.form-select(class=errors.status ? 'is-invalid' : '', name='status', required)
            each optionValue in statusOptions
              option(value=optionValue, selected=((asset && asset.status) ? asset.status === optionValue : optionValue === 'Available'))= optionValue
          if errors.status
            .invalid-feedback.d-block= errors.status
      .action-cluster.mt-4
        button.btn.btn-primary(type='submit') Save Asset
        a.btn.btn-secondary(href='/asset') Cancel
