extends layout

block content
  .page-header
    div
      h1.page-title #{action} Employee
      p.page-subtitle Capture clean identity and employment lifecycle data so issue and return flows stay reliable.

  .panel
    form(method='POST', action=(action === 'Add' ? '/employee/add' : '/employee/edit/' + employee.id), novalidate)
      .row.g-3
        .col-md-6
          label.form-label(for='name') Name
          input#name.form-control(class=errors.name ? 'is-invalid' : '', type='text', name='name', required, value=employee.name || '')
          if errors.name
            .invalid-feedback.d-block= errors.name
        .col-md-6
          label.form-label(for='email') Email
          input#email.form-control(class=errors.email ? 'is-invalid' : '', type='email', name='email', required, value=employee.email || '')
          if errors.email
            .invalid-feedback.d-block= errors.email
        .col-md-4
          label.form-label(for='status') Status
          select#status.form-select(class=errors.status ? 'is-invalid' : '', name='status')
            each optionValue in statusOptions
              option(value=optionValue, selected=((employee.status || 'active') === optionValue))= optionValue
          if errors.status
            .invalid-feedback.d-block= errors.status
        .col-md-4
          label.form-label(for='join_date') Join Date
          input#join_date.form-control(class=errors.join_date ? 'is-invalid' : '', type='date', name='join_date', value=(employee.join_date || ''))
          if errors.join_date
            .invalid-feedback.d-block= errors.join_date
        .col-md-4
          label.form-label(for='leave_date') Leave Date
          input#leave_date.form-control(class=errors.leave_date ? 'is-invalid' : '', type='date', name='leave_date', value=(employee.leave_date || ''))
          if errors.leave_date
            .invalid-feedback.d-block= errors.leave_date
      .action-cluster.mt-4
        button.btn.btn-success(type='submit') Save Employee
        a.btn.btn-secondary(href='/employee') Cancel
