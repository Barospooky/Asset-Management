doctype html
html
  head
    title= title ? `${title} - Asset Management System` : 'Asset Management System'
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin='anonymous')
    link(href='https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap', rel='stylesheet')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css', rel='stylesheet')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css', rel='stylesheet')
    link(href='https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css', rel='stylesheet')
    link(href='/public/css/app.css', rel='stylesheet')

  body
    .app-shell
      - var messages = pageMessages || { error: [], success: [] }
      nav.navbar.navbar-expand-xl.topbar
        .container-fluid.g-3
          a.brand(href='/employee')
            span.brand-mark AM
            span.brand-text
              strong Asset Management
              span Secure inventory operations
          button.navbar-toggler.bg-light(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav', aria-controls='navbarNav', aria-expanded='false', aria-label='Toggle navigation')
            span.navbar-toggler-icon
          #navbarNav.collapse.navbar-collapse
            ul.navbar-nav.me-auto.mb-2.mb-xl-0
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/employee')) ? 'active' : '', href='/employee')
                  i.bi.bi-people-fill.me-2
                  | Employees
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/assetcategory')) ? 'active' : '', href='/assetcategory')
                  i.bi.bi-tags-fill.me-2
                  | Categories
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/asset')) ? 'active' : '', href='/asset')
                  i.bi.bi-pc-display-horizontal.me-2
                  | Assets
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/stock')) ? 'active' : '', href='/stock')
                  i.bi.bi-box-seam-fill.me-2
                  | Stock
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/issue')) ? 'active' : '', href='/issue')
                  i.bi.bi-box-arrow-up-right.me-2
                  | Issue
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/return')) ? 'active' : '', href='/return')
                  i.bi.bi-arrow-return-left.me-2
                  | Return
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/scrap')) ? 'active' : '', href='/scrap')
                  i.bi.bi-trash3-fill.me-2
                  | Scrap
              li.nav-item
                a.nav-link(class=(currentPath && currentPath.startsWith('/history')) ? 'active' : '', href='/history')
                  i.bi.bi-clock-history.me-2
                  | History
            if currentUser
              .d-flex.flex-column.flex-xl-row.align-items-xl-center.gap-2.ms-xl-3
                .user-pill
                  i.bi.bi-shield-lock-fill
                  span
                    small Signed in
                    strong= currentUser.email
                form(action='/auth/logout', method='POST')
                  button.logout-button(type='submit')
                    i.bi.bi-box-arrow-right.me-2
                    | Logout

      .container-fluid.px-0
        if messages.error.length
          each message in messages.error
            .alert.alert-danger.alert-dismissible.fade.show.mb-3(role='alert')
              = message
              button.btn-close(type='button', data-bs-dismiss='alert', aria-label='Close')
        if messages.success.length
          each message in messages.success
            .alert.alert-success.alert-dismissible.fade.show.mb-3(role='alert')
              = message
              button.btn-close(type='button', data-bs-dismiss='alert', aria-label='Close')
        block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
    script(src='https://code.jquery.com/jquery-3.7.0.min.js')
    script(src='https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js')

