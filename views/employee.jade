extends layout

block content
  .page-header
    div
      h1.page-title Employee Directory
      p.page-subtitle Manage active and inactive team members with clean records, searchable lists, and stronger validation.
    .action-cluster
      a.btn.btn-success(href='/employee/add')
        i.bi.bi-person-plus-fill.me-2
        | Add Employee

  .panel
    form(method='GET', action='/employee')
      .row.g-3
        .col-lg-5
          label.form-label(for='search') Search by name
          input#search.form-control(type='text', name='search', placeholder='Search employees', value=searchText)
        .col-lg-3
          label.form-label(for='status') Filter by status
          select#status.form-select(name='status')
            option(value='all', selected=selectedStatus === 'all') All employees
            option(value='active', selected=selectedStatus === 'active') Active
            option(value='inactive', selected=selectedStatus === 'inactive') Inactive
        .col-lg-4.d-flex.align-items-end
          .action-cluster
            button.btn.btn-primary(type='submit') Apply Filters
            a.btn.btn-secondary(href='/employee') Reset

  .panel
    .table-shell
      table#employeeTable.table.table-striped.table-bordered
        thead
          tr
            th S No.
            th Name
            th Email
            th Status
            th Join Date
            th Leave Date
            th Action
        tbody
          each emp, index in employees
            - const employeeStatusClass = emp.status === 'active' ? 'status-active' : 'status-inactive';
            tr
              td= index + 1
              td= emp.name
              td= emp.email
              td
                span.badge-soft(class=employeeStatusClass)= emp.status
              td= emp.join_date ? new Date(emp.join_date).toLocaleDateString('en-GB') : ''
              td= emp.leave_date ? new Date(emp.leave_date).toLocaleDateString('en-GB') : ''
              td
                .action-cluster
                  a.btn.btn-primary.btn-sm(href='/employee/edit/' + emp.id) Edit
                  form.inline-form(action='/employee/delete/' + emp.id, method='POST', onsubmit='return confirm("Delete this employee?")')
                    button.btn.btn-danger.btn-sm(type='submit') Delete

  script.
    $(document).ready(function () {
      $('#employeeTable').DataTable({
        searching: false,
        autoWidth: false
      });
    });
