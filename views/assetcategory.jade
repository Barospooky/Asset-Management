extends layout

block content
  .page-header
    div
      h1.page-title Asset Categories
      p.page-subtitle Keep category names controlled so assets, stock views, and lifecycle workflows all use the same vocabulary.
    .action-cluster
      a.btn.btn-success(href='/assetcategory/add')
        i.bi.bi-plus-circle-fill.me-2
        | Add Category

  .panel
    .table-shell
      table.table.table-bordered.table-striped
        thead
          tr
            th S No.
            th Name
            th Description
            th Actions
        tbody
          if assetcategories.length
            each item,index in assetcategories
              tr
                td= index + 1
                td= item.name
                td= item.description
                td
                  .action-cluster
                    a.btn.btn-primary.btn-sm(href='/assetcategory/edit/' + item.id) Edit
                    form.inline-form(action='/assetcategory/delete/' + item.id, method='POST', onsubmit='return confirm("Delete this category?")')
                      button.btn.btn-danger.btn-sm(type='submit') Delete
          else
            tr
              td(colspan='4') No asset categories found.
