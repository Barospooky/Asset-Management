doctype html
html
  head
    title= title ? `${title} - Asset Management System` : 'Asset Management System'
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin='anonymous')
    link(href='https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap', rel='stylesheet')
    link(rel='stylesheet', href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css')
    link(rel='stylesheet', href='/public/css/app.css')
  body
    .auth-shell
      .auth-card
        - var messages = pageMessages || { error: [], success: [] }
        .auth-eyebrow Asset Operations
        h1.auth-title= title || 'Sign in'
        p.auth-copy Access employee, inventory, issue, and audit workflows from one secure control center.
        if messages.error.length
          each message in messages.error
            .alert.alert-danger= message
        if messages.success.length
          each message in messages.success
            .alert.alert-success= message
        block content
