extends layout

block content
  .page-header
    div
      h1.page-title Asset Registry
      p.page-subtitle Keep every device traceable with unique serial numbers, category mapping, lifecycle status, and cleaner operational controls.
    .action-cluster
      a.btn.btn-success(href='/asset/add')
        i.bi.bi-plus-circle-fill.me-2
        | Add Asset

  .panel
    form(action='/asset', method='get')
      .row.g-3
        .col-lg-5
          label.form-label(for='assetcategory') Filter by category
          select#assetcategory.form-select(name='assetcategory')
            option(value='') All categories
            each category in categories
              option(value=category.name, selected=(assetCategory == category.name))= category.name
        .col-lg-4.d-flex.align-items-end
          .action-cluster
            button.btn.btn-primary(type='submit') Apply Filter
            a.btn.btn-secondary(href='/asset') Reset

  .panel
    .table-shell
      table#assetTable.table.table-striped.table-bordered
        thead
          tr
            th S No.
            th Serial No.
            th Make
            th Model
            th Category
            th Status
            th Actions
        tbody
          each asset, index in assets
            - const assetStatusClass = asset.status === 'Available' ? 'status-available' : (asset.status === 'Issued' ? 'status-issued' : 'status-scraped');
            tr
              td= index + 1
              td= asset.serial_number
              td= asset.make
              td= asset.model
              td= asset.asset_type
              td
                span.badge-soft(class=assetStatusClass)= asset.status
              td
                .action-cluster
                  a.btn.btn-primary.btn-sm(href='/asset/edit/' + asset.id) Edit
                  form.inline-form(action='/asset/delete/' + asset.id, method='POST', onsubmit='return confirm("Delete this asset?")')
                    button.btn.btn-danger.btn-sm(type='submit') Delete

  script.
    $(document).ready(function () {
      $('#assetTable').DataTable();
    });
