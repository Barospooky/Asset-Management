extends layout

block content
  .page-header
    div
      h1.page-title Return Asset
      p.page-subtitle Validate the employee, category, and asset before an issued device moves back into available stock.

  .panel
    if errors.form
      .alert.alert-danger= errors.form
    form(action='/return/new', method='post', novalidate)
      .row.g-3
        .col-md-6
          label.form-label(for='employee_id') Employee
          select#employee_id.form-select(class=errors.employee_id ? 'is-invalid' : '', name='employee_id', required)
            option(value='') -- Select Employee --
            each emp in employees
              option(value=emp.id, selected=String(formData.employee_id || '') === String(emp.id))= emp.name
          if errors.employee_id
            .invalid-feedback.d-block= errors.employee_id
        .col-md-6
          label.form-label(for='asset_category_id') Asset Category
          select#asset_category_id.form-select(class=errors.asset_category_id ? 'is-invalid' : '', name='asset_category_id', required)
            option(value='') -- Select Category --
            each c in categories
              option(value=c.id, selected=String(formData.asset_category_id || '') === String(c.id))= c.name
          if errors.asset_category_id
            .invalid-feedback.d-block= errors.asset_category_id
        .col-md-6
          label.form-label(for='asset_id') Asset
          select#asset_id.form-select(class=errors.asset_id ? 'is-invalid' : '', name='asset_id', required)
            option(value='') -- Select Asset --
            each a in availableAssets
              option(value=a.id, selected=String(formData.asset_id || '') === String(a.id))= `${a.serial_number} - ${a.make} ${a.model}`
          if errors.asset_id
            .invalid-feedback.d-block= errors.asset_id
        .col-md-6
          label.form-label(for='return_date') Return Date
          input#return_date.form-control(class=errors.return_date ? 'is-invalid' : '', type='date', name='return_date', value=formData.return_date || returnDate)
          if errors.return_date
            .invalid-feedback.d-block= errors.return_date
        .col-12
          label.form-label(for='remarks') Return Remarks
          textarea#remarks.form-control(class=errors.remarks ? 'is-invalid' : '', name='remarks', rows='4')= formData.remarks || ''
          if errors.remarks
            .invalid-feedback.d-block= errors.remarks
      .action-cluster.mt-4
        button.btn.btn-primary(type='submit') Return Asset


